# Deployment ortam degiskenleri
# Bu dosyayi .env olarak kopyalayin ve degerleri doldurun:
#   cp .env.example .env

# Guvenli bir anahtar uretmek icin:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=leyl-pastane-change-this-secret-key-32

# Port ayarlari (opsiyonel, varsayilan: 3000 ve 8000)
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Token sureleri
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
